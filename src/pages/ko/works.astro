---
import Layout from "../../layouts/Layout.astro";
import { WorksTabs } from "../../components/WorksTabs";
import { useTranslations } from "../../i18n/ui";

const lang = "ko";
const t = useTranslations(lang);

const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;

const query = `
{
  viewer {
    pullRequests(first: 50, states: MERGED, orderBy: {field: CREATED_AT, direction: DESC}) {
      nodes {
        title
        url
        createdAt
        repository {
          name
        }
      }
    }
    issues(last: 50, orderBy: {field: CREATED_AT, direction: DESC}) {
      nodes {
        title
        url
        createdAt
        repository {
          name
        }
      }
    }
    contributionsCollection {
      pullRequestReviewContributions(last: 50) {
        nodes {
          pullRequest {
            title
            url
            repository {
              name
            }
          }
          occurredAt
        }
      }
    }
  }
}
`;

let contributions = {
  prs: [],
  issues: [],
  reviews: []
};

try {
  if (GITHUB_TOKEN) {
    const response = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${GITHUB_TOKEN}`,
      },
      body: JSON.stringify({ query }),
    });

    const json = (await response.json()) as any;

    if (json.data?.viewer) {
      const viewer = json.data.viewer;
      contributions = {
        prs: viewer.pullRequests?.nodes || [],
        issues: viewer.issues?.nodes || [],
        reviews: viewer.contributionsCollection?.pullRequestReviewContributions?.nodes.map((node: any) => ({
          title: node.pullRequest.title,
          url: node.pullRequest.url,
          createdAt: node.occurredAt,
          repository: node.pullRequest.repository
        })) || []
      };
    }
  }
} catch (e) {
  console.error("Failed to fetch GitHub contributions:", e);
}

const techStack = [
  { name: "Astro", repo: "astro" },
  { name: "Astro-Docs", repo: "docs" },
  { name: "Qwik", repo: "qwik" },
  { name: "Yamada UI", repo: "yamada-ui" },
  { name: "Dioxus", repo: "dioxus" },
  { name: "Dioxus-Docs", repo: "docsite" },
  { name: "Valibot", repo: "valibot" }
];

const products = [
  {
    title: "My Portfolio",
    description: "This website built with Astro and Tailwind CSS.",
    url: "https://github.com/yourname/portfolio",
    tech: ["Astro", "TypeScript", "TailwindCSS"]
  },
  {
    title: "Sample App",
    description: "A simple todo application built with React.",
    url: "https://github.com/yourname/sample-app",
    tech: ["React", "Vite"]
  },
];
---

<Layout title={t("meta.works.title")} description={t("meta.works.description")}>
  <main class="max-w-4xl mx-auto pt-32 pb-20 px-6">
    <div class="mb-12">
      <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-2">{t("works.heading")}</h1>
      <p class="text-slate-500 dark:text-slate-400 font-medium">{t("works.subheading")}</p>
    </div>

    <WorksTabs 
      client:load 
      lang={lang}
      products={products} 
      contributions={contributions} 
      techStack={techStack} 
    />
  </main>
</Layout>
