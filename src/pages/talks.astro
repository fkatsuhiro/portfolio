---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar";
import SlideCard from "../components/SlideCard";

const slideSources = [
    {
        id: "tskaigi-hokuriku-2025",
        link: "https://hokuriku.tskaigi.org/talks/27",
        slideLink:
            "https://docs.google.com/presentation/d/e/2PACX-1vRly5O8x6P9GXrExPxZlbsg203HxjFbEIcviYryzMkMoivRSaR8xs9xADKngYdOScSr0lLVlswkfSmn/pubembed?start=false&loop=false&delayms=3000",
        title: "TSKaigi Hokuriku 2025",
        sidebarLabel: "TSKaigi Hokuriku 2025 LT",
        time: "2025/11/23(Sat) 14:30 ~",
        description:
            "「Zod × Web Worker を用いた型安全かつUIファーストなIPアドレス一括登録」",
    },
    {
        id: "reacttokyo-fes-2026",
        link: "https://react-tokyo.vercel.app/fes2026",
        slideLink:
            "https://docs.google.com/presentation/d/e/2PACX-1vQsbEJTJpsvlexQ8qKkAjQpNd2xNBaBH5Y8sDSTuhixbrbdyjQzYLu5TzI6SWyXgKBG6X2jvJo3t3N1/pubembed?start=false&loop=false&delayms=3000",
        title: "React Tokyo Fes 2026",
        sidebarLabel: "React Tokyo Fes 2026",
        time: "2026/2/28(Sat)",
        description: "Zod v4リリースによる新機能活用法を考える",
    },
];

const sidebarItems = slideSources.map((s) => ({
    id: s.id,
    label: s.sidebarLabel,
}));
---

<Layout title="Talks">
    <div
        class="min-h-screen pt-20 md:pt-20 flex flex-col md:flex-row bg-gray-50 dark:bg-gray-950"
    >
        <div
            class="hidden md:block w-full md:w-1/3 lg:w-1/4 p-6 transform md:translate-x-8 md:translate-y-12"
        >
            <Sidebar title="TALKS" items={sidebarItems} client:load />
        </div>

        <main class="w-full md:w-2/3 lg:w-3/4 py-8 px-6 md:px-16">
            <div
                class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8"
            >
                {
                    slideSources.map((slide) => (
                        <SlideCard
                            id={slide.id}
                            title={slide.title}
                            link={slide.link}
                            time={slide.time}
                            description={slide.description}
                            slideLink={slide.slideLink}
                            client:visible
                        />
                    ))
                }
            </div>
        </main>
    </div>
</Layout>
