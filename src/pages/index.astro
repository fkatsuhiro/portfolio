---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import ThemeToggle from "../components/ThemeToggle";
import HomeImage from "../assets/homeImg.png";
import PageLinkBlock from "../components/PageLinkBlock";
import { useTranslations, type Lang } from "../i18n/ui";

const lang = (Astro.currentLocale ?? "ja") as Lang;
const t = useTranslations(lang);

const basePath = import.meta.env.BASE_URL;

const menuLinks = [
    {
        title: t("home.menu.about.title"),
        href: `${basePath}/about`,
        desc1: t("home.menu.about.desc1"),
        desc2: t("home.menu.about.desc2"),
    },
    {
        title: t("home.menu.works.title"),
        href: `${basePath}/works`,
        desc1: t("home.menu.works.desc1"),
        desc2: t("home.menu.works.desc2"),
    },
    {
        title: t("home.menu.talks.title"),
        href: `${basePath}/talks`,
        desc1: t("home.menu.talks.desc1"),
        desc2: t("home.menu.talks.desc2"),
    },
    {
        title: t("home.menu.blogs.title"),
        href: `${basePath}/blogs`,
        desc1: t("home.menu.blogs.desc1"),
        desc2: t("home.menu.blogs.desc2"),
    },
];
---

<Layout
    title={t("meta.home.title")}
    description={t("meta.home.description")}
>
    <main>
        <section
            data-hero
            class="relative h-screen w-full flex overflow-hidden"
        >
            <div class="absolute top-4 right-4 z-20">
                <ThemeToggle client:load />
            </div>

            <div
                class="w-1/2 h-full flex flex-col justify-center md:justify-end p-4 md:p-16 z-10 bg-white dark:bg-gray-950"
            >
                <div class="mb-0 md:mb-40 ml-6 md:mx-10 mt-12 md:mt-0">
                    <h1
                        class="text-xl sm:text-2xl md:text-5xl font-bold tracking-tight text-gray-900 dark:text-white leading-tight break-words"
                    >
                        Furuichi Katsuhiro
                    </h1>
                    <p
                        class="mt-2 md:mt-4 text-xs sm:text-sm md:text-xl text-gray-500 dark:text-gray-400"
                    >
                        {t("home.role")}
                    </p>
                </div>
            </div>

            <div
                class="w-1/2 h-full bg-white dark:bg-gray-950 flex items-center justify-center relative"
            >
                <Image
                    src={HomeImage}
                    alt="Portrait of Furuichi Katsuhiro"
                    loading="eager"
                    fetchpriority="high"
                    class="w-4/5 md:w-3/5 h-auto md:h-3/5 object-contain"
                />
            </div>

            <div
                class="absolute bottom-8 left-0 w-full flex flex-col items-center gap-1 z-10 pointer-events-none"
            >
                <span class="text-xs text-gray-400 dark:text-gray-500 tracking-widest uppercase"
                    >{t("home.scrollDown")}</span
                >
                <span class="block w-px h-8 bg-gray-300 dark:bg-gray-600 animate-pulse"
                ></span>
            </div>
        </section>

        <section class="min-h-screen py-20 px-4 max-w-4xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 pt-20">
                {
                    menuLinks.map((link) => (
                        <PageLinkBlock
                            href={link.href}
                            title={link.title}
                            desc1={link.desc1}
                            desc2={link.desc2}
                            client:visible
                        />
                    ))
                }
            </div>
        </section>
    </main>
</Layout>
