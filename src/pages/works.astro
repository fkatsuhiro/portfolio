---
import Layout from "../layouts/Layout.astro";
import { ContributionCard } from "../components/ContributionCard";

interface GitHubResponse {
  data: {
    viewer: {
      pullRequests: {
        nodes: Array<{
          title: string;
          url: string;
          createdAt: string;
          repository: {
            name: string;
          };
        }>;
      };
    };
  };
}

const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;

const query = `
{
  viewer {
    pullRequests(states: MERGED, last: 50, orderBy: {field: CREATED_AT, direction: DESC}) {
      nodes {
        title
        url
        createdAt
        repository {
          name
        }
      }
    }
  }
}
`;

let allPrs = [];
try {
  const response = await fetch("https://api.github.com/graphql", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      Authorization: `Bearer ${GITHUB_TOKEN}`,
    },
    body: JSON.stringify({ query }),
  });

  const json = (await response.json()) as GitHubResponse;
  allPrs = json.data?.viewer?.pullRequests?.nodes || [];
} catch (e) {
  console.error("GitHub APIの取得に失敗しました:", e);
}

const techStack = [
  { name: "Astro", repo: "astro" },
  { name: "Astro-Docs", repo: "docs" },
  { name: "Qwik", repo: "qwik" },
  { name: "Yamada UI", repo: "yamada-ui" },
  { name: "Dioxus", repo: "dioxus" },
  { name: "Dioxus-Docs", repo: "docsite" }
];
---

<Layout title="Works">
  <main class="max-w-4xl mx-auto pt-32 pb-20 px-6">
    <div class="mb-16">
      <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-2">OSS Comtribution</h1>
      <p class="text-slate-500 dark:text-slate-400 font-medium">My contributions to the open source community.</p>
    </div>

    <div class="space-y-20">
      {techStack.map((tech) => {
        const filteredPrs = allPrs.filter(pr => 
          pr.repository.name.toLowerCase().includes(tech.repo.toLowerCase())
        );
        if (filteredPrs.length === 0) return null;

        return (
          <section class="animate-in fade-in slide-in-from-bottom-4 duration-700">
            <div class="flex items-center gap-4 mb-8">
              <h2 class="text-2xl font-bold text-slate-800 dark:text-slate-100 tracking-tight">
                {tech.name}
              </h2>
              <div class="h-[1px] flex-grow bg-gradient-to-r from-slate-200 to-transparent dark:from-slate-800"></div>
              <span class="text-xs font-mono text-slate-400 bg-slate-50 dark:bg-slate-900 px-2 py-1 rounded border border-slate-100 dark:border-slate-800">
                {filteredPrs.length} items
              </span>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              {filteredPrs.map(pr => (
                <ContributionCard 
                  title={pr.title}
                  url={pr.url}
                  repoName={pr.repository.name}
                  date={pr.createdAt}
                />
              ))}
            </div>
          </section>
        );
      })}
    </div>

    {allPrs.length === 0 && (
      <div class="py-20 text-center border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-2xl">
        <p class="text-slate-500 text-lg">No contributions found. Check your GITHUB_TOKEN.</p>
      </div>
    )}
  </main>
</Layout>